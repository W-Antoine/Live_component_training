        <h1>Layan Training</h1>
        <p class="subtitle">Apprendre Stimulus et Symfony UX Live Component step by step</p>
    </header>

    <main class="cards">
        <a href="{{ path('learning', {file: 'questionnaire'}) }}" class="card">
